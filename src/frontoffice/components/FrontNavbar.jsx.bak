import React, { useState, useEffect } from 'react';
import { ShoppingBag, User, Menu, X, ChefHat, LogOut, LayoutDashboard } from 'lucide-react';

const FrontNavbar = ({
  navigate,
  currentPage,
  currentCustomer,
  openAuth,
  handleLogout,
  cartCount,
  onGoToBackoffice,
}) => {
  const [scrolled, setScrolled] = useState(false);
  const [mobileOpen, setMobileOpen] = useState(false);

  useEffect(() => {
    const handleScroll = () => setScrolled(window.scrollY > 20);
    window.addEventListener('scroll', handleScroll);
    return () => window.removeEventListener('scroll', handleScroll);
  }, []);

  const navLinks = [
    { label: 'Accueil', page: 'home' },
    { label: 'Menu', page: 'menu' },
    { label: 'Notre Histoire', page: 'home', anchor: 'story' },
    { label: 'Commander', page: 'dine-in' },
  ];

  const handleNav = (link) => {
    navigate(link.page);
    if (link.anchor) {
      setTimeout(() => {
        const el = document.getElementById(link.anchor);
        if (el) el.scrollIntoView({ behavior: 'smooth' });
      }, 100);
    }
    setMobileOpen(false);
  };

  return (
    <nav
      className={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${
        scrolled
          ? 'bg-black/95 backdrop-blur-md border-b border-white/10 py-3'
          : 'bg-transparent py-5'
      }`}
    >
      <div className="max-w-7xl mx-auto px-6 flex items-center justify-between">
        {/* Logo */}
        <button
          onClick={() => navigate('home')}
          className="flex items-center space-x-3 group"
        >
          <div className="w-9 h-9 rounded-full bg-gradient-to-br from-orange-500 to-red-600 flex items-center justify-center shadow-lg shadow-orange-500/30 group-hover:shadow-orange-500/50 transition-all">
            <ChefHat size={18} className="text-white" />
          </div>
          <span className="text-xl font-bold tracking-tight">
            <span className="text-white">Salmon</span>
            <span className="text-orange-500"> Sushi</span>
          </span>
        </button>

        {/* Desktop Links */}
        <div className="hidden md:flex items-center space-x-8">
          {navLinks.map((link) => (
            <button
              key={link.label}
              onClick={() => handleNav(link)}
              className={`text-sm font-medium transition-colors ${
                currentPage === link.page && !link.anchor
                  ? 'text-orange-400'
                  : 'text-zinc-300 hover:text-white'
              }`}
            >
              {link.label}
            </button>
          ))}
        </div>

        {/* Right Side Actions */}
        <div className="flex items-center space-x-2">
          {/* Staff Backoffice Button */}
          {onGoToBackoffice && (
            <button
              onClick={onGoToBackoffice}
              className="hidden md:flex items-center space-x-1.5 px-3 py-1.5 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-orange-500/30 rounded-full text-xs text-zinc-400 hover:text-orange-400 transition-all"
              title="Accès équipe"
            >
              <LayoutDashboard size={13} />
              <span>Staff</span>
            </button>
          )}

          {/* Cart */}
          <button
            onClick={() => navigate('dine-in')}
            className="relative p-2 text-zinc-300 hover:text-white transition-colors"
          >
            <ShoppingBag size={20} />
            {cartCount > 0 && (
              <span className="absolute -top-1 -right-1 w-5 h-5 bg-orange-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center">
                {cartCount > 9 ? '9+' : cartCount}
              </span>
            )}
          </button>

          {/* Auth / Profile */}
          {currentCustomer ? (
            <div className="flex items-center space-x-2">
              <button
                onClick={() => navigate('profile')}
                className="flex items-center space-x-2 px-3 py-1.5 bg-white/10 hover:bg-white/15 border border-white/20 rounded-full text-sm text-white transition-all"
              >
                <span className="w-6 h-6 rounded-full bg-gradient-to-br from-orange-400 to-red-500 flex items-center justify-center text-xs font-bold">
                  {currentCustomer.name.charAt(0).toUpperCase()}
                </span>
                <span className="hidden sm:block max-w-[80px] truncate">{currentCustomer.name.split(' ')[0]}</span>
              </button>
              <button
                onClick={handleLogout}
                className="p-2 text-zinc-400 hover:text-white transition-colors"
                title="Déconnexion"
              >
                <LogOut size={16} />
              </button>
            </div>
          ) : (
            <button
              onClick={() => openAuth('login')}
              className="flex items-center space-x-2 px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold rounded-full transition-all shadow-lg shadow-orange-500/20 hover:shadow-orange-500/40"
            >
              <User size={16} />
              <span className="hidden sm:block">Mon Compte</span>
            </button>
          )}

          {/* Mobile Menu Toggle */}
          <button
            onClick={() => setMobileOpen(!mobileOpen)}
            className="md:hidden p-2 text-zinc-300 hover:text-white transition-colors"
          >
            {mobileOpen ? <X size={22} /> : <Menu size={22} />}
          </button>
        </div>
      </div>

      {/* Mobile Menu */}
      {mobileOpen && (
        <div className="md:hidden absolute top-full left-0 right-0 bg-black/98 border-b border-white/10 px-6 py-4 space-y-1">
          {navLinks.map((link) => (
            <button
              key={link.label}
              onClick={() => handleNav(link)}
              className="w-full text-left py-3 text-sm font-medium text-zinc-300 hover:text-white border-b border-white/5 last:border-0 transition-colors"
            >
              {link.label}
            </button>
          ))}
          {!currentCustomer && (
            <div className="pt-3 flex space-x-3">
              <button
                onClick={() => { openAuth('login'); setMobileOpen(false); }}
                className="flex-1 py-2 bg-white/10 border border-white/20 rounded-lg text-sm text-white font-medium"
              >
                Connexion
              </button>
              <button
                onClick={() => { openAuth('signup'); setMobileOpen(false); }}
                className="flex-1 py-2 bg-orange-500 rounded-lg text-sm text-white font-medium"
              >
                S'inscrire
              </button>
            </div>
          )}
          {/* Staff access in mobile menu */}
          {onGoToBackoffice && (
            <div className="pt-2 border-t border-white/5">
              <button
                onClick={() => { onGoToBackoffice(); setMobileOpen(false); }}
                className="w-full flex items-center space-x-2 py-2.5 text-xs text-zinc-500 hover:text-orange-400 transition-colors"
              >
                <LayoutDashboard size={14} />
                <span>Accès Staff / Backoffice</span>
              </button>
            </div>
          )}
        </div>
      )}
    </nav>
  );
};

export default FrontNavbar;
